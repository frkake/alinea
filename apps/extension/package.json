{
  "name": "@alinea/extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "build:edge": "wxt build -b edge",
    "zip": "wxt zip",
    "zip:edge": "wxt zip -b edge",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "e2e": "playwright test",
    "audit:live-arxiv": "node scripts/live-arxiv-audit.mjs",
    "e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@alinea/api-client": "workspace:*",
    "@alinea/tokens": "workspace:*",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.0",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "@vitejs/plugin-react": "4.6.0",
    "jsdom": "26.1.0",
    "typescript": "5.8.3",
    "vitest": "3.2.4",
    "wxt": "0.20.7",
    "@playwright/test": "1.53.2"
  }
}
