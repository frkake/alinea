{
  "name": "@yakudoku/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:pw": "playwright test --project=e2e",
    "e2e:vr": "playwright test --project=visual",
    "e2e:update": "playwright test --project=visual --update-snapshots",
    "e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@tanstack/react-query": "5.81.5",
    "@yakudoku/tokens": "workspace:*",
    "clsx": "2.1.1",
    "next": "15.4.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "zustand": "5.0.6",
    "@yakudoku/api-client": "workspace:*",
    "katex": "0.16.22",
    "pdfjs-dist": "4.10.38"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.11",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.0.10",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "@vitejs/plugin-react": "4.6.0",
    "jsdom": "26.1.0",
    "tailwindcss": "4.1.11",
    "typescript": "5.8.3",
    "vitest": "3.2.4",
    "@types/katex": "0.16.7",
    "@playwright/test": "1.53.2"
  }
}
