# Alinea — 環境変数の雛形(秘匿値は空)。cp .env.example .env して使う。
# 命名規約: 大文字 SNAKE_CASE。ブラウザ露出は NEXT_PUBLIC_ / WXT_ 接頭辞のみ(秘匿値に付けない)。
# 出典: plans/00 §5.2 + plans/01 §8.4 + plans/12 §15(ベース URL 上書き)。

# --- 実行環境 ---
APP_ENV=development                # development | production(挙動分岐は settings.py に集約)
APP_BASE_URL=http://localhost:3000 # Web の公開 URL(本番: https://alinea.app)。共有リンク・メールリンク生成に使用
API_BASE_URL=http://localhost:8000 # API の公開 URL
API_INTERNAL_URL=http://localhost:8000 # web の SSR fetch 先(本番 compose 内: http://api:8000)

# --- DB / Redis / S3 ---
DATABASE_URL=postgresql+asyncpg://alinea:alinea@localhost:5432/alinea
REDIS_URL=redis://localhost:6379/0
S3_ENDPOINT_URL=http://localhost:9000        # 本番(R2): https://<accountid>.r2.cloudflarestorage.com
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000 # ブラウザから到達可能な署名 endpoint(本番未設定=ENDPOINT と同一)
S3_REGION=us-east-1                          # R2 では auto
S3_ACCESS_KEY_ID=alinea
S3_SECRET_ACCESS_KEY=alinea-dev-secret
S3_BUCKET_SOURCES=alinea-sources           # SourceAsset 原本(LaTeX tar・PDF 原本)
S3_BUCKET_ASSETS=alinea-assets             # 派生物(図・サムネ・概要図 SVG・解説図ラスター)

# --- 認証・セッション ---
SESSION_SECRET=change-me-64-hex              # セッション/state/メールリンク署名鍵(openssl rand -hex 32)
ALINEA_KEY_ENCRYPTION_SECRET=_yrt0TUSAA01enlCc7d-0KAGCyZnn9LjiqhZ7hOahQo= # dev用。prod は Fernet.generate_key() で別鍵を生成
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
# dev: 未設定(chrome-extension:// を一律許可)。prod: chrome-extension://<ChromeストアID>,chrome-extension://<EdgeストアID>
EXTENSION_ALLOWED_ORIGINS=

# --- メール(マジックリンク) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=login@alinea.app

# --- LLM / 画像生成(運営キー。BYOK はユーザーごとに DB 暗号化保存) ---
# GPT テキスト + gpt-image-2
OPENAI_API_KEY=
# Claude(claude-opus-4-8 / claude-sonnet-5 / claude-haiku-4-5)
ANTHROPIC_API_KEY=
# Gemini テキスト + 画像(GEMINI_API_KEY でも可。GEMINI が優先)
GOOGLE_API_KEY=
# deepseek-v4-flash / v4-pro(OpenAI互換 base_url=https://api.deepseek.com)
DEEPSEEK_API_KEY=
# grok-4.3 / grok-imagine-image(OpenAI互換 base_url=https://api.x.ai/v1)
XAI_API_KEY=

# --- LLM ベース URL 上書き(E2E/CI のモックサーバ差し替え。plans/12 §15-2,3) ---
# 空=各社既定。E2E: http://localhost:8090/v1
ALINEA_OPENAI_BASE_URL=
ALINEA_ANTHROPIC_BASE_URL=
ALINEA_GOOGLE_BASE_URL=
ALINEA_DEEPSEEK_BASE_URL=
ALINEA_XAI_BASE_URL=
# 空=https://arxiv.org。E2E: http://localhost:8090/arxiv
ALINEA_ARXIV_BASE_URL=

# --- 外部サービス ---
ARXIV_USER_AGENT="alinea/1.0 (contact: admin@alinea.app)"  # docs/09 §5.3 の規約遵守
# LaTeX 由来論文の日本語PDFビルド用イメージ。
# 事前に: docker build -f docker/texlive/Dockerfile -t alinea-texlive-ja:latest .
ALINEA_TEXLIVE_IMAGE=alinea-texlive-ja:latest
ALINEA_LATEX_BUILD_TIMEOUT_S=360
# リソースメタ取得(スター数等)のレート制限緩和(任意)
GITHUB_API_TOKEN=
# リソースメタ取得(再生時間)(任意)
YOUTUBE_API_KEY=

# --- 計測(docs/09 §8 テレメトリ)---
# 空なら無効。本番で設定
OTEL_EXPORTER_OTLP_ENDPOINT=
# api+worker
SENTRY_DSN_API=
# web
SENTRY_DSN_WEB=

# --- apps/web(ブラウザ露出可のみ) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- apps/extension(ビルド時埋め込み。露出可のみ) ---
WXT_API_BASE_URL=http://localhost:8000
WXT_APP_BASE_URL=http://localhost:3000
