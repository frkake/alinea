# 訳読 / YAKUDOKU — 環境変数の雛形(秘匿値は空)。cp .env.example .env して使う。
# 命名規約: 大文字 SNAKE_CASE。ブラウザ露出は NEXT_PUBLIC_ / WXT_ 接頭辞のみ(秘匿値に付けない)。
# 出典: plans/00 §5.2 + plans/01 §8.4 + plans/12 §15(ベース URL 上書き)。

# --- 実行環境 ---
APP_ENV=development                # development | production(挙動分岐は settings.py に集約)
APP_BASE_URL=http://localhost:3000 # Web の公開 URL(本番: https://yakudoku.app)。共有リンク・メールリンク生成に使用
API_BASE_URL=http://localhost:8000 # API の公開 URL
API_INTERNAL_URL=http://localhost:8000 # web の SSR fetch 先(本番 compose 内: http://api:8000)

# --- DB / Redis / S3 ---
DATABASE_URL=postgresql+asyncpg://yakudoku:yakudoku@localhost:5432/yakudoku
REDIS_URL=redis://localhost:6379/0
S3_ENDPOINT_URL=http://localhost:9000        # 本番(R2): https://<accountid>.r2.cloudflarestorage.com
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000 # ブラウザから到達可能な署名 endpoint(本番未設定=ENDPOINT と同一)
S3_REGION=us-east-1                          # R2 では auto
S3_ACCESS_KEY_ID=yakudoku
S3_SECRET_ACCESS_KEY=yakudoku-dev-secret
S3_BUCKET_SOURCES=yakudoku-sources           # SourceAsset 原本(LaTeX tar・PDF 原本)
S3_BUCKET_ASSETS=yakudoku-assets             # 派生物(図・サムネ・概要図 SVG・解説図ラスター)

# --- 認証・セッション ---
SESSION_SECRET=change-me-64-hex              # セッション/state/メールリンク署名鍵(openssl rand -hex 32)
YAKUDOKU_KEY_ENCRYPTION_SECRET=change-me-fernet-key # BYOK APIキーの Fernet マスタキー(python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
EXTENSION_ALLOWED_ORIGINS=                   # dev: 未設定(chrome-extension:// を一律許可)。prod: chrome-extension://<ChromeストアID>,chrome-extension://<EdgeストアID>

# --- メール(マジックリンク) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=login@yakudoku.app

# --- LLM / 画像生成(運営キー。BYOK はユーザーごとに DB 暗号化保存) ---
OPENAI_API_KEY=                    # GPT テキスト + gpt-image-2
ANTHROPIC_API_KEY=                 # Claude(claude-opus-4-8 / claude-sonnet-5 / claude-haiku-4-5)
GOOGLE_API_KEY=                    # Gemini テキスト + gemini-3.1-flash-image / gemini-3-pro-image
DEEPSEEK_API_KEY=                  # deepseek-v4-flash / v4-pro(OpenAI互換 base_url=https://api.deepseek.com)
XAI_API_KEY=                       # grok-4.3 / grok-imagine-image(OpenAI互換 base_url=https://api.x.ai/v1)

# --- LLM ベース URL 上書き(E2E/CI のモックサーバ差し替え。plans/12 §15-2,3) ---
YAKUDOKU_OPENAI_BASE_URL=          # 空=各社既定。E2E: http://localhost:8090/v1
YAKUDOKU_ANTHROPIC_BASE_URL=
YAKUDOKU_GOOGLE_BASE_URL=
YAKUDOKU_DEEPSEEK_BASE_URL=
YAKUDOKU_XAI_BASE_URL=
YAKUDOKU_ARXIV_BASE_URL=           # 空=https://arxiv.org。E2E: http://localhost:8090/arxiv

# --- 外部サービス ---
ARXIV_USER_AGENT="yakudoku/1.0 (contact: admin@yakudoku.app)"  # docs/09 §5.3 の規約遵守
GITHUB_API_TOKEN=                  # リソースメタ取得(スター数等)のレート制限緩和(任意)
YOUTUBE_API_KEY=                   # リソースメタ取得(再生時間)(任意)

# --- 計測(docs/09 §8 テレメトリ)---
OTEL_EXPORTER_OTLP_ENDPOINT=       # 空なら無効。本番で設定
SENTRY_DSN_API=                    # api+worker
SENTRY_DSN_WEB=                    # web

# --- apps/web(ブラウザ露出可のみ) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- apps/extension(ビルド時埋め込み。露出可のみ) ---
WXT_API_BASE_URL=http://localhost:8000
WXT_APP_BASE_URL=http://localhost:3000
