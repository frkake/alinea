# dependencies
node_modules/
.pnpm-store/
.venv/
__pycache__/
*.egg-info/
*.pyc

# ppt-master: dedicated venv + its lock + transient conversion output.
# NOTE: this ignores ONLY the local venv/output — the submodule-tracked files
# under vendor/ppt-master/ are intentionally NOT ignored.
.venv-ppt-master/
.venv-ppt-master.lock.txt
ppt-master-output/

# build outputs
.turbo/
.next/
.output/
dist/
build/
coverage/
!tools/coverage/
.nyc_output/
.coverage
.hypothesis/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.worktrees/

# NOTE: generated files that ARE committed (drift checks depend on tracking them):
#   packages/tokens/css/accents.css (pnpm gen), packages/api-client/src/generated (openapi-ts)
# so they are intentionally NOT ignored here.

# env & secrets
.env
.env.local
.env.*.local
!.env.example

# playwright
playwright-report/
test-results/
apps/web/e2e/.auth/

# local end-to-end audit output
/artifacts/

# misc
.DS_Store
*.log
*.tsbuildinfo

# Local UAT DB safety backups (contains sessions + encrypted BYOK) - never commit
.uat-backups/
