{
  "name": "alinea",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": "24.4.0"
  },
  "scripts": {
    "predev": "pnpm --filter @alinea/api-client build && pnpm --filter @alinea/tokens build && bash scripts/dev-docker.sh compose up -d && bash scripts/dev-docker.sh compose up -d --wait db redis minio mailpit && pnpm --dir apps/api db:migrate && bash scripts/ensure-texlive-image.sh && pnpm --dir apps/worker latex-pdf:backfill",
    "dev": "turbo dev",
    "dev:clean": "bash scripts/dev-clean.sh",
    "dev:down": "bash scripts/dev-docker.sh compose stop",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ppt-master:update": "bash scripts/update-ppt-master.sh",
    "ppt-master:smoke": "bash scripts/ppt-master-smoke.sh"
  },
  "devDependencies": {
    "@eslint/js": "9.30.1",
    "@types/node": "24.0.10",
    "eslint": "9.30.1",
    "eslint-config-prettier": "10.1.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "prettier": "3.6.2",
    "turbo": "2.5.4",
    "typescript": "5.8.3",
    "typescript-eslint": "8.36.0"
  }
}
